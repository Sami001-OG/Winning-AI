{
  "rewrites": [
    {
      "source": "/api/proxy/fapi/:match*",
      "destination": "https://fapi.binance.com/fapi/:match*"
    },
    {
      "source": "/api/proxy/api/:match*",
      "destination": "https://api.binance.com/api/:match*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
